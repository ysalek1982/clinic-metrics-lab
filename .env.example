# Public browser configuration
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<publishable-anon-key>

# Local CLI and QA only. Never commit real values.
SUPABASE_ACCESS_TOKEN=<supabase-access-token>
SUPABASE_DB_PASSWORD=<database-password>
E2E_EMAIL=<e2e-user-email>
E2E_PASSWORD=<e2e-user-password>

QA_NO_MEMBERSHIP_EMAIL=<qa-no-membership-email>
QA_NO_MEMBERSHIP_PASSWORD=<qa-no-membership-password>
QA_HSM_EMAIL=<qa-hsm-email>
QA_HSM_PASSWORD=<qa-hsm-password>
QA_TENANT_B_EMAIL=<qa-tenant-b-email>
QA_TENANT_B_PASSWORD=<qa-tenant-b-password>
QA_TENANT_B_ID=<qa-tenant-b-id>

# Edge Function secret. Configure in Supabase, not in frontend.
SUPABASE_SERVICE_ROLE_KEY=<edge-function-service-role-key>
